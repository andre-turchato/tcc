# Variáveis de ambiente — Longevus Backend
# Copie este arquivo para .env e preencha os valores reais

# Porta e host do servidor HTTP
PORT=3000
HOST=0.0.0.0

# Credenciais do Supabase (obtenha em: Supabase > Project Settings > API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your_service_role_key

# TTL do cache in-memory em segundos (padrão: 300 = 5 minutos)
CACHE_TTL_SECONDS=300
